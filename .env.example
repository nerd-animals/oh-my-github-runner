RUNNER_ROOT=/home/ubuntu/runner-deploy
RUNNER_POLL_INTERVAL_MS=2000
RUNNER_MAX_CONCURRENCY=2
RUNNER_LOG_RETENTION_DAYS=3
RUNNER_QUEUE_RETENTION_DAYS=7

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=/etc/oh-my-github-runner/github-app.pem
GITHUB_WEBHOOK_SECRET=replace-with-the-secret-set-in-the-github-app
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEB_BASE_URL=https://github.com

# Sender allowlist — comma-separated GitHub user IDs allowed to trigger tasks.
# Find your id with: gh api /users/<login> --jq .id
# Required: webhook events from any other sender are dropped.
ALLOWED_SENDER_IDS=12345678

# Webhook server (bind to localhost; Cloudflare tunnel terminates TLS upstream)
WEBHOOK_PORT=8080
WEBHOOK_HOST=127.0.0.1

# Tools — set `<NAME>_COMMAND` to the binary path for each tool you want to
# enable on this host. Each supported tool has a corresponding ToolRunner
# implementation under `src/infra/tool/`; argv, rate-limit signatures, and
# artifact cleanup live there. Strategy code decides which tool runs each
# task — there's no per-comment selection. The runner refuses to start if
# no <NAME>_COMMAND is set.
CLAUDE_COMMAND=/home/ubuntu/.local/bin/claude
# CODEX_COMMAND=/usr/local/bin/codex

# Rate limit
RATE_LIMIT_COOLDOWN_MS=3600000

# Optional: override the bot user id lookup (skips GET /app at startup)
# BOT_USER_ID=12345678
